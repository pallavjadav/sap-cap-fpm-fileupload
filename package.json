{
  "name": "fileuploadfpm",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/notifications": "^0.3.0",
    "@sap/cds": "^9",
    "@sap/hana-client": "^2.29.23",
    "@sap/xssec": "^4",
    "read-excel-file": "^9.2.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@sap/hdi-deploy": "5.7.0",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-books": "cds watch --open books/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy fileuploadfpm --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-deadletterqueue": "cds watch --open deadletterqueue/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "outbox": {
      "kind": "persistent-outbox"
    },
    "requires": {
      "OutboxTestService": {
        "kind": "local"
      },
      "queue": {
        "kind": "persistent-queue",
        "maxAttempts": 100,
        "storeLastError": true,
        "legacyLocking": true,
        "timeout": "1h"
      },
      "db": "hana",
      "[production]": {
        "auth": "xsuaa"
      },
      "html5-repo": true,
      "application-logging": true,
      "destinations": true,
      "workzone": true
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/books",
    "app/deadletterqueue"
  ]
}
